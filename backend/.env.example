# =============================================
# Scientific Navigator — Environment Template
# =============================================
# Copy this file to .env and fill in real values.

# --- Django Core ---
SECRET_KEY=change-me-to-a-real-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database (Postgres) ---
DB_ENGINE=django.db.backends.postgresql
DB_NAME=navigator
DB_USER=navigator
DB_PASSWORD=navigator
DB_HOST=localhost
DB_PORT=5432

# --- CORS ---
CORS_ALLOW_ALL=True

# --- Ollama ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_KEEP_ALIVE=30m
OLLAMA_NUM_PARALLEL=2
OLLAMA_MAX_LOADED_MODELS=2

# --- Chroma ---
CHROMA_PERSIST_DIR=data/chroma

# --- RAG / QA performance (quality-preserving defaults) ---
RAG_QA_USE_HYBRID=True
RAG_QA_USE_MULTI_QUERY=False
RAG_QA_USE_RERANKING=True
RAG_QA_TOP_K=8
RAG_LLM_MODEL=mistral
RAG_LLM_NUM_PREDICT=320
RAG_LLM_TEMPERATURE=0.2
RAG_LLM_NUM_CTX=4096
RAG_LLM_KEEP_ALIVE=30m

# --- External Provider Resilience ---
# Retry attempts per external call (arXiv/PubMed/Semantic Scholar connectors)
EXTERNAL_API_RETRIES=3
# Initial backoff (seconds), doubles each retry
EXTERNAL_API_RETRY_BACKOFF_SECONDS=1.0
# Open circuit after this many consecutive failed calls per provider
EXTERNAL_API_CIRCUIT_FAILURE_THRESHOLD=5
# Time (seconds) the provider circuit stays open before allowing requests again
EXTERNAL_API_CIRCUIT_OPEN_SECONDS=60

# --- External Provider Credentials / Contact ---
OPENALEX_MAILTO=
OPENALEX_API_KEY=
CORE_API_KEY=
UNPAYWALL_EMAIL=
